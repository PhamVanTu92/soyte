<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode: chạy src/server.js làm entry point -->
    <handlers>
      <add name="iisnode" path="src/server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Bỏ qua request debug của iisnode -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^src/server.js\/debug[\/]?" />
        </rule>

        <!-- Static files (uploads, v.v.) — trả về trực tiếp, không qua Node -->
        <rule name="StaticContent" stopProcessing="true">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Tất cả request còn lại → chuyển đến Node.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="src/server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Cho phép IIS truy cập thư mục bin (node_modules cần) -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Trả lỗi từ Node.js thay vì IIS error page -->
    <httpErrors existingResponse="PassThrough" />

    <!-- Cấu hình iisnode -->
    <iisnode
      node_env="production"
      nodeProcessCommandLine="node"
      loggingEnabled="true"
      logDirectory="logs\iisnode"
      maxLogFileSizeInKB="128"
      maxTotalLogFileSizeInKB="2048"
      maxLogFiles="20"
      devErrorsEnabled="false"
      watchedFiles="web.config;*.js"
    />

  </system.webServer>
</configuration>
