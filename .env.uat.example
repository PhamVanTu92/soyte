# ── UAT Environment ───────────────────────────────────────────────
# Copy file này thành .env.uat rồi điền giá trị thực

# Port expose ra host (prod dùng 3000, UAT dùng 3001)
APP_PORT=3001

# Database UAT — nên dùng DB riêng, không dùng chung với prod
DB_HOST=host.docker.internal
DB_PORT=35432
DB_NAME=suckhuoethudo_uat_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# JWT — dùng secret khác với prod
JWT_SECRET=uat_jwt_secret_change_this
JWT_EXPIRES_IN=1d

# URL — trỏ vào domain UAT
FRONTEND_URL=https://uat.suckhoethudo.vn
APP_BASE_URL=https://backend-uat.suckhoethudo.vn
ALLOWED_ORIGINS=https://uat.suckhoethudo.vn,http://localhost:5173

# Email — có thể dùng mailtrap hoặc tắt đi cho UAT
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
